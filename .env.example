# Copy this file to .env and fill in real values. .env is gitignored — never commit real secrets.

# Secret used to authenticate calls to /admin/* endpoints (setting limits,
# viewing usage). Generate a long random string — this is YOUR key, not a
# provider key. Devs using the proxy never see or need this.
PROXY_ADMIN_KEY=

# NOTE: there is no Anthropic/OpenAI key here on purpose. This proxy passes
# the dev's own provider key through per-request (their Authorization/
# x-api-key header, forwarded upstream) — it never holds provider
# credentials itself.
