# Copy this file to .env and fill in real values. .env is gitignored — never commit real keys.

# Anthropic usage/cost reporting requires an Admin API key (separate from a normal API key).
ANTHROPIC_ADMIN_KEY=

# OpenAI usage endpoints similarly require elevated credentials.
OPENAI_API_KEY=

# How often fetch_usage.py polls provider APIs, in minutes.
FETCH_INTERVAL_MINUTES=60
